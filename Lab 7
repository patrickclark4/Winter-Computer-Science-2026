// Lab 7: part 1
#include <iostream>
#include <cstring>
using namespace std;

const int ASCII_START = 1;
const int ASCII_END = 126;
const int BLOCK_SIZE = 256;

// encrypts a single character using the key
// wraps around so we stay within ASCII 1-126
char encryptChar(char plainChar, int key) {
    if (plainChar == '\0')
        return '\0';

    int range = ASCII_END - ASCII_START + 1;

    // make sure key is positive and fits in our range
    key = ((key % range) + range) % range;

    int shifted = (int)plainChar - ASCII_START;
    shifted = (shifted + key) % range;

    return (char)(shifted + ASCII_START);
}

// encrypts a whole char array one character at a time
void encryptArray(const char plainText[], char cipherText[], int size, int key) {
    for (int i = 0; i < size; i++)
        cipherText[i] = encryptChar(plainText[i], key);
}

// decryption is just encryption backwards
void decryptArray(char plainText[], const char cipherText[], int size, int key) {
    encryptArray(cipherText, plainText, size, -key);
}

int main() {

    // test 1: print plain vs cipher for all printable characters
    cout << "Plain\tCipher" << endl;
    int testKey = 3;
    for (int i = 32; i <= 126; i++) {
        char plain = (char)i;
        char cipher = encryptChar(plain, testKey);
        cout << plain << "\t" << cipher << endl;
    }

    // test 2: encrypt a message then decrypt it and make sure we get the original back
    char plainText[BLOCK_SIZE] = "This message is written in plain text and you can read it!";
    char cipherText[BLOCK_SIZE] = {};
    char decryptedText[BLOCK_SIZE] = {};
    int key = 7;

    encryptArray(plainText, cipherText, BLOCK_SIZE, key);
    decryptArray(decryptedText, cipherText, BLOCK_SIZE, key);

    cout << "\nPlain Text:     " << plainText << endl;
    cout << "Cipher Text:    " << cipherText << endl;
    cout << "Decrypted Text: " << decryptedText << endl;

    if (strcmp(plainText, decryptedText) == 0)
        cout << "\nSuccess - decrypted text matches the original!" << endl;
    else
        cout << "\nSomething went wrong, texts don't match." << endl;

    return 0;
}


