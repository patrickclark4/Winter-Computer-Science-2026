#include <iostream>
#include <cstring>
using namespace std;

const int ASCII_START = 1;
const int ASCII_END = 126;
const int BLOCK_SIZE = 512;

char encryptChar(char plainChar, int key) {
    if (plainChar == '\0')
        return '\0';

    int range = ASCII_END - ASCII_START + 1;
    key = ((key % range) + range) % range;

    int shifted = (int)plainChar - ASCII_START;
    shifted = (shifted + key) % range;

    return (char)(shifted + ASCII_START);
}

void encryptArray(const char plainText[], char cipherText[], int size, int key) {
    for (int i = 0; i < size; i++)
        cipherText[i] = encryptChar(plainText[i], key);
}

void decryptArray(char plainText[], const char cipherText[], int size, int key) {
    encryptArray(cipherText, plainText, size, -key);
}

// overloaded versions that take a key array instead of a single key
void encryptArray(const char plainText[], char cipherText[], int size,
                  const int keyArr[], int keyLength) {
    for (int i = 0; i < size; i++) {
        int k = keyArr[i % keyLength];
        cipherText[i] = encryptChar(plainText[i], k);
    }
}

void decryptArray(char plainText[], const char cipherText[], int size,
                  const int keyArr[], int keyLength) {
    for (int i = 0; i < size; i++) {
        int k = keyArr[i % keyLength];
        plainText[i] = encryptChar(cipherText[i], -k);
    }
}

// tries all possible key combos and checks if the decrypted text contains "the"
// if it shows up enough times its probably the right key
void bruteForce3(char plainText[], const char cipherText[], int size, int minThe) {
    char trial[BLOCK_SIZE] = {};

    for (int i = ASCII_START; i < ASCII_END; i++) {
        for (int j = ASCII_START; j < ASCII_END; j++) {
            for (int k = ASCII_START; k < ASCII_END; k++) {

                int trialKey[3] = {i, j, k};
                decryptArray(trial, cipherText, size, trialKey, 3);

                int theCount = 0;
                for (int idx = 0; idx < size - 4; idx++) {
                    if (trial[idx] == ' ' && trial[idx+1] == 't' &&
                        trial[idx+2] == 'h' && trial[idx+3] == 'e' &&
                        trial[idx+4] == ' ')
                        theCount++;
                }

                if (theCount >= minThe) {
                    cout << "Key {" << i << ", " << j << ", " << k << "}"
                         << " -> found " << theCount << " instances of \" the \"" << endl;
                    memcpy(plainText, trial, size);
                }
            }
        }
    }
}

